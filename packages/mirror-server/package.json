{
  "name": "overleaf-cli",
  "version": "2.0.0",
  "description": "CLI tool for Overleaf file synchronization and terminal",
  "main": "dist/index.js",
  "bin": {
    "overleaf-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "overleaf",
    "latex",
    "sync",
    "cli",
    "terminal",
    "file-sync"
  ],
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
